# Ders Seçim Chatbot — Environment Configuration
# Copy this to .env and adjust values

# Qdrant Vector Database
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=ders_secim_docs

# LLM Server (llama.cpp OpenAI-compatible)
LLAMA_CPP_URL=http://localhost:8080
LLAMA_CPP_MODEL=auto
LLAMA_CPP_TIMEOUT=300

# Router LLM endpoints (easy=CPU, hard=GPU)
EASY_LLM_URL=http://localhost:8080
HARD_LLM_URL=http://localhost:8081

# Embedding
EMBED_MODEL=all-MiniLM-L6-v2
EMBED_DEVICE=cuda

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=128

# Search
TOP_K=5
SIM_THRESHOLD=0.25

# Admin / Güvenlik
# Bu key /api/qdrant/reset endpoint'ini korur.
# X-Reset-Key header'ı olarak gönderilmelidir.
# Boş bırakılırsa endpoint KORUMASIZ kalır — MUTLAKA doldur!
RESET_API_KEY=change_me_to_a_strong_secret
